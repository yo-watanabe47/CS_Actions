@model CS_Actions_WebApp.Models.ProductListViewModel
@{
   Layout = null;
}
<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>商品一覧 - CI/CD デモアプリ</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <div class="container mt-5">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h2 class="h5 mb-0">📦 商品一覧画面(ASP.NET Core)</h2>
            </div>
            <div class="card-body">
                
                @if (Model.Products != null && Model.Products.Any())
                {
                    <table class="table table-bordered table-hover mt-3">
                        <thead class="table-light">
                            <tr>
                                <th scope="col" style="width: 8%">ID</th>
                                <th scope="col" style="width: 32%">商品UUID</th>
                                <th scope="col" style="width: 40%">商品名</th>
                                <th scope="col" style="width: 20%">価格 (円)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var product in Model.Products)
                            {
                                <tr>
                                    <td class="text-end">@product.Id</td>
                                    <td class="text-muted" style="font-size: 0.85em;">@product.ProductUuid</td>
                                    <td>@product.Name</td>
                                    <td class="text-end text-danger fw-bold">@product.Price?.ToString("N0")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="alert alert-warning text-center mt-3">
                        データベースに商品が登録されていません。
                    </div>
                }

            </div>
        </div>
    </div>
</body>
</html>